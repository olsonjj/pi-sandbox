#!/usr/bin/env bash
set -euo pipefail

# pi-sandbox — Run Pi (or any coding agent) in a throwaway Docker container.
# Only the current project directory is mounted. No home dir, no ~/.ssh, no secrets.
#
# Usage:
#   pi-sandbox                          # interactive
#   pi-sandbox -p "refactor this"       # print mode
#   pi-sandbox --model sonnet           # pass through any pi flags
#   pi-sandbox --network                # allow outbound network (needed for API)
#   pi-sandbox --mount ~/.pi/agent      # mount additional path
#   pi-sandbox --image my-image         # use custom Docker image
#   pi-sandbox --rebuild                # force rebuild of Docker image
#   pi-sandbox --version                # show version information
#   cat file.txt | pi-sandbox -p "summarize"
#
# First run builds a Docker image (one-time). Subsequent runs are instant.
# Use --rebuild to force a fresh build (e.g. to pick up new pi versions).

IMAGE_NAME="${PI_SANDBOX_IMAGE:-pi-sandbox}"
NODE_VERSION="${PI_SANDBOX_NODE:-22}"
CONTAINER_WORKDIR="/workspace"
SANDBOX_HOME="/tmp/pi-sandbox-home"

# ── Parse wrapper-specific flags ──────────────────────────────────────────
# Flags consumed by this wrapper (--network, --mount, etc.) are handled here.
# Everything else is collected in PASSTHROUGH_ARGS and forwarded to pi.
NETWORK="none"
EXTRA_MOUNTS=()
PASSTHROUGH_ARGS=()
COMMAND="pi"
REBUILD="false"

# ── Guards ─────────────────────────────────────────────────────────────────
# These are required for mount paths. Fail early with a clear message.
if [[ -z "${PWD:-}" ]]; then
  echo "❌ PWD is not set" >&2
  exit 1
fi
if [[ -z "${HOME:-}" ]]; then
  echo "❌ HOME is not set" >&2
  exit 1
fi

# Capture host user/group for tmpfs ownership and --user flag
HOST_UID=$(id -u)
HOST_GID=$(id -g)

while [[ $# -gt 0 ]]; do
  case "$1" in
    --network)
      NETWORK="bridge"
      shift
      ;;
    --network=*)
      NETWORK="${1#*=}"
      shift
      ;;
    --mount)
      EXTRA_MOUNTS+=("$2")
      shift 2
      ;;
    --mount=*)
      EXTRA_MOUNTS+=("${1#*=}")
      shift
      ;;
    --image)
      IMAGE_NAME="$2"
      shift 2
      ;;
    --image=*)
      IMAGE_NAME="${1#*=}"
      shift
      ;;
    --cmd)
      COMMAND="$2"
      shift 2
      ;;
    --cmd=*)
      COMMAND="${1#*=}"
      shift
      ;;
    --rebuild)
      REBUILD="true"
      shift
      ;;
    --version)
      # Resolve symlinks to find the real script location
      SCRIPT_PATH="$0"
      while [[ -L "$SCRIPT_PATH" ]]; do
        SCRIPT_DIR_TMP="$(dirname "$SCRIPT_PATH")"
        SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
        [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$SCRIPT_DIR_TMP/$SCRIPT_PATH"
      done
      SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
      WRAPPER_VERSION="unknown"
      if [[ -f "$SCRIPT_DIR/package.json" ]]; then
        WRAPPER_VERSION=$(node -e "console.log(require('$SCRIPT_DIR/package.json').version)" 2>/dev/null || echo "unknown")
      fi
      echo "pi-sandbox $WRAPPER_VERSION"
      if command -v docker &>/dev/null && docker image inspect "$IMAGE_NAME" &>/dev/null 2>&1; then
        IMAGE_PI_VERSION=$(docker run --rm --entrypoint pi "$IMAGE_NAME" --version 2>/dev/null || echo "unknown")
        echo "image pi: $IMAGE_PI_VERSION"
      fi
      exit 0
      ;;
    --help)
      echo "pi-sandbox — run Pi in an isolated Docker container"
      echo ""
      echo "Usage: pi-sandbox [wrapper-flags] [pi-flags...]"
      echo ""
      echo "Wrapper flags (must come before pi flags):"
      echo "  --network        Enable outbound network (default: none)"
      echo "  --network=<mode> Set Docker network mode (bridge, host, none)"
      echo "  --mount <path>   Mount additional host path into container"
      echo "  --image <name>   Use custom Docker image (default: pi-sandbox)"
      echo "  --cmd <command>  Command to run inside container (default: pi)"
      echo "  --rebuild        Force rebuild of the Docker image"
      echo "  --version        Show version information"
      echo "  --help           Show this help"
      echo ""
      echo "All other arguments are passed through to pi."
      echo ""
      echo "Examples:"
      echo "  pi-sandbox --network"
      echo "  pi-sandbox --network -p 'refactor the auth module'"
      echo "  pi-sandbox --network --model sonnet:high"
      echo "  pi-sandbox --mount ~/.pi/agent/skills --network"
      echo "  cat README.md | pi-sandbox --network -p 'summarize'"
      exit 0
      ;;
    *)
      PASSTHROUGH_ARGS+=("$1")
      shift
      ;;
  esac
done

# ── Check prerequisites ───────────────────────────────────────────────────
# Docker must be installed and the daemon running. Podman is not supported.
if ! command -v docker &>/dev/null; then
  echo "❌ Docker is not installed. Install it first: https://docs.docker.com/get-docker/" >&2
  exit 1
fi

if ! docker info &>/dev/null; then
  echo "❌ Docker daemon is not running. Start Docker Desktop and try again." >&2
  exit 1
fi

# ── Build image if needed ─────────────────────────────────────────────────
# The image is built once and reused. It includes:
#   - node (specified by NODE_VERSION) as the base
#   - pi installed globally (--ignore-scripts for safety)
#   - git, ripgrep, fd-find for agent use
#   - A clean HOME at /tmp/pi-sandbox-home (tmpfs at runtime)
#
# --rebuild uses --no-cache for a fresh build. The old image is kept until
# the new build succeeds, so a failed rebuild doesn't leave you stranded.
if [[ "$REBUILD" == "true" ]]; then
  echo "🔨 Rebuilding sandbox image '$IMAGE_NAME' (--no-cache)..." >&2
fi

if ! docker image inspect "$IMAGE_NAME" &>/dev/null || [[ "$REBUILD" == "true" ]]; then
  echo "🔨 Building sandbox image '$IMAGE_NAME'..." >&2
  TMPDIR=$(mktemp -d)
  # Clean up temp directory on exit (build failure, interrupt, etc.)
  trap "rm -rf '$TMPDIR'" EXIT
  cat > "$TMPDIR/Dockerfile" <<'DOCKERFILE'
ARG NODE_VERSION=22
FROM node:${NODE_VERSION}-slim

# Install pi globally (--ignore-scripts for safety)
RUN npm install -g --ignore-scripts @earendil-works/pi-coding-agent

# Create a clean home for the container user
RUN mkdir -p /tmp/pi-sandbox-home && chmod 755 /tmp/pi-sandbox-home

# Install basic tools the agent might need
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    ripgrep \
    fd-find \
    && ln -s /usr/bin/fdfind /usr/local/bin/fd \
    && rm -rf /var/lib/apt/lists/*

ENV HOME=/tmp/pi-sandbox-home
ENV PI_CODING_AGENT_DIR=/tmp/pi-sandbox-home/.pi/agent
WORKDIR /workspace
CMD ["pi"]
DOCKERFILE
  BUILD_ARGS=(--build-arg NODE_VERSION="$NODE_VERSION")
  [[ "$REBUILD" == "true" ]] && BUILD_ARGS+=(--no-cache)
  docker build "${BUILD_ARGS[@]}" -t "$IMAGE_NAME" "$TMPDIR" >&2
  rm -rf "$TMPDIR"
  trap - EXIT
  echo "✅ Image built successfully." >&2
fi

# ── Warn if image is stale ────────────────────────────────────────────────
# Images older than 30 days may have outdated pi or unpatched CVEs.
# This is a non-blocking warning; use --rebuild to force a refresh.
if [[ "$REBUILD" != "true" ]]; then
  CREATED=$(docker image inspect --format '{{.Created}}' "$IMAGE_NAME" 2>/dev/null)
  if [[ -n "$CREATED" ]]; then
    # Parse the Docker timestamp (format: 2024-01-15T10:30:00.123456789Z)
    CREATED_EPOCH=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${CREATED%%.*}" +%s 2>/dev/null || date -d "$CREATED" +%s 2>/dev/null || echo "0")
    NOW_EPOCH=$(date +%s)
    AGE_DAYS=$(( (NOW_EPOCH - CREATED_EPOCH) / 86400 ))
    if (( AGE_DAYS > 30 )); then
      echo "⚠️  Sandbox image is $AGE_DAYS days old. Consider: pi-sandbox --rebuild" >&2
    fi
  fi
fi

# ── Collect API key environment variables ─────────────────────────────────
# Forward known provider API keys from the host into the container.
# Only keys that are actually set are passed through (no empty vars).
# Also forward any PI_* vars for pi-specific configuration.
ENV_ARGS=()
for VAR in ANTHROPIC_API_KEY OPENAI_API_KEY GOOGLE_API_KEY GROQ_API_KEY \
           DEEPSEEK_API_KEY MISTRAL_API_KEY XAI_API_KEY CEREBRAS_API_KEY \
           GEMINI_API_KEY VERTEX_AI_KEY AZURE_OPENAI_API_KEY \
           BEDROCK_AWS_ACCESS_KEY_ID BEDROCK_AWS_SECRET_ACCESS_KEY \
           OPENROUTER_API_KEY CLOUDFLARE_API_KEY TOGETHER_API_KEY \
           FIREWORKS_API_KEY HUGGINGFACE_API_KEY OLLAMA_API_KEY; do
  if [[ -n "${!VAR:-}" ]]; then
    ENV_ARGS+=(-e "$VAR=${!VAR}")
  fi
done

# Also pass through PI_* env vars
for VAR in $(env | grep '^PI_' | cut -d= -f1); do
  ENV_ARGS+=(-e "$VAR=${!VAR}")
done

# ── Build mount arguments ─────────────────────────────────────────────────
# Security design:
#   - $PWD mounted read-write (the project you're working on)
#   - node_modules is an anonymous volume (isolates from host)
#   - /tmp and $SANDBOX_HOME are tmpfs (ephemeral, in-memory)
#   - ~/.pi/agent mounted read-write (pi needs lock files + sessions)
#   - Extra mounts (--mount flag) default to read-only
MOUNT_ARGS=(
  -v "$PWD:$CONTAINER_WORKDIR:rw"
  # Anonymous volume for node_modules (don't leak host node_modules)
  -v "$CONTAINER_WORKDIR/node_modules"
  # tmpfs for writable temp areas (must come BEFORE bind mounts)
  --tmpfs /tmp:exec,uid=$HOST_UID,gid=$HOST_GID
  --tmpfs "$SANDBOX_HOME:exec,uid=$HOST_UID,gid=$HOST_GID"
  # Mount Pi config read-write (pi needs to write lock files + sessions)
  -v "$HOME/.pi/agent:$SANDBOX_HOME/.pi/agent:rw"
)

if [[ ${#EXTRA_MOUNTS[@]} -gt 0 ]]; then
  for mount_path in "${EXTRA_MOUNTS[@]}"; do
    # Expand ~ in paths
    expanded="${mount_path/#\~/$HOME}"
    # Skip if this would duplicate the default ~/.pi/agent mount
    if [[ "$expanded" == "$HOME/.pi/agent" ]]; then
      echo "⚠️  Skipping --mount ~/.pi/agent (already mounted by default)" >&2
      continue
    fi
    if [[ -e "$expanded" ]]; then
      MOUNT_ARGS+=(-v "$expanded:$expanded:ro")
    else
      echo "⚠️  Mount path does not exist, skipping: $expanded" >&2
    fi
  done
fi

# ── Run container ─────────────────────────────────────────────────────────
# Security hardening:
#   --rm              Remove container on exit (no leftover state)
#   --cap-drop=ALL    Drop all Linux capabilities
#   --no-new-privileges  Prevent privilege escalation via setuid
#   --user            Run as the host user (not root)
#   --network none    No outbound network by default
#
# TTY handling:
#   -it   Interactive terminal (stdin + stdout are TTYs)
#   -i    Piped input (stdin is not a TTY, e.g. cat file | pi-sandbox)
TTY_ARGS=()
if [[ -t 0 && -t 1 ]]; then
  TTY_ARGS=(-it)
else
  TTY_ARGS=(-i)
fi

exec docker run \
  --rm \
  "${TTY_ARGS[@]}" \
  --network "$NETWORK" \
  --cap-drop=ALL \
  --security-opt=no-new-privileges \
  --user "$HOST_UID:$HOST_GID" \
  --hostname pi-sandbox \
  "${MOUNT_ARGS[@]}" \
  "${ENV_ARGS[@]}" \
  "$IMAGE_NAME" \
  "$COMMAND" \
  "${PASSTHROUGH_ARGS[@]:-}"
